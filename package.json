{
  "name": "ai-security-copilot",
  "displayName": "SecureStack Copilot",
  "description": "Detects security vulnerabilities and provides AI-powered fixes.",
  "publisher": "SecureStack",
  "icon": "images/icon.png",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sarfas10/securestack-copilot"
  },
  "version": "1.1.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
  "onStartupFinished"
],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiSecurityCopilot.fixAllInFile",
        "title": "🛡️ Fix All Issues in File",
        "category": "SecureStack"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "aiSecurityCopilot.fixAllInFile",
          "group": "navigation",
          "when": "editorFocus"
        }
      ],
      "editor/context": [
        {
          "command": "aiSecurityCopilot.fixAllInFile",
          "when": "editorFocus",
          "group": "1_modification@100"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
  
}