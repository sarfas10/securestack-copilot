{
  "name": "ai-security-copilot",
  "displayName": "SecureStack Copilot",
  "description": "Detects security vulnerabilities and provides AI-powered fixes.",
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiSecurityCopilot.fixAllInFile",
        "title": "🛡️ Fix All Issues in File",
        "category": "SecureStack"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aiSecurityCopilot.fixAllInFile",
          "when": "editorFocus",
          "group": "1_modification@100"
        }
      ],
      "editor/title": [
        {
          "command": "aiSecurityCopilot.fixAllInFile",
          "when": "editorFocus",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
